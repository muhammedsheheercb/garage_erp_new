# Neon pooled PostgreSQL connection string. Use this exact value for the web
# deployment and the Electron-launched Next.js server.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Long random value shared by the web deployment and Electron server.
AUTH_SECRET="replace-with-a-long-random-secret"

# Keep this stable for production builds when Server Actions are deployed to
# more than one web instance.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="replace-with-a-base64-encoded-32-byte-key"
