generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id        String    @id @default(uuid())
  name      String
  email     String?   @unique
  phone     String?
  address   String?
  type      String?   @default("Individual")
  vehicles  Vehicle[]
  jobCards  JobCard[]
  invoices  Invoice[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Vehicle {
  id           String    @id @default(uuid())
  brand        String
  model        String
  year         Int?
  fuelType     String?
  plateNumber  String    @unique
  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id])
  jobCards     JobCard[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model VehicleCompany {
  id        String         @id @default(uuid())
  name      String         @unique
  models    VehicleModel[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model VehicleModel {
  id        String         @id @default(uuid())
  name      String
  companyId String
  company   VehicleCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([companyId, name])
}

model Mechanic {
  id        String    @id @default(uuid())
  name      String
  phone     String?
  email     String?   @unique
  jobCards  JobCard[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Service {
  id          String           @id @default(uuid())
  name        String
  price       Float
  estimatedTime String?
  category    String?
  jobCards    JobCardService[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model JobCard {
  id             String           @id @default(uuid())
  status         String           @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  complaint      String
  workDone       String?
  estimatedCost  Float?
  notes          String?
  customerId     String
  customer       Customer         @relation(fields: [customerId], references: [id])
  vehicleId      String
  vehicle        Vehicle          @relation(fields: [vehicleId], references: [id])
  mechanicId     String
  mechanic       Mechanic         @relation(fields: [mechanicId], references: [id])
  services       JobCardService[]
  parts          JobCardPart[]
  
  serviceTotal   Float            @default(0)
  partsTotal     Float            @default(0)
  discount       Float            @default(0)
  tax            Float            @default(0)
  grandTotal     Float            @default(0)

  invoice        Invoice?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

// Join table for many-to-many relationship between JobCard and Service
model JobCardService {
  id        String   @id @default(uuid())
  jobCardId String
  jobCard   JobCard  @relation(fields: [jobCardId], references: [id])
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id])
  quantity  Int      @default(1)
  price     Float    // Captures the price at the time of service
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobCardId, serviceId])
}

model JobCardPart {
  id          String         @id @default(uuid())
  jobCardId   String
  jobCard     JobCard        @relation(fields: [jobCardId], references: [id])
  batchId     String
  batch       InventoryBatch @relation(fields: [batchId], references: [id])
  quantity    Int            @default(1)
  price       Float          // Selling price at the time of use
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([jobCardId, batchId])
}

model Invoice {
  id              String    @id @default(uuid())
  amount          Float     // Kept for backward compatibility, same as grandTotal
  serviceCharge   Float     @default(0)
  labourCharge    Float     @default(0)
  partsCost       Float     @default(0)
  discount        Float     @default(0)
  tax             Float     @default(0)
  subTotal        Float     @default(0)
  grandTotal      Float     @default(0)
  otherCharges    String?   // JSON string of other charges
  servicesDetails String?   // Text to store services details
  partsDetails    String?   // Text or JSON string to store parts used
  status          String    @default("UNPAID") // UNPAID, PARTIAL, PAID
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])
  jobCardId       String    @unique
  jobCard         JobCard   @relation(fields: [jobCardId], references: [id])
  payments        Payment[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Payment {
  id        String   @id @default(uuid())
  amount    Float
  method    String   // CASH, CARD, TRANSFER
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id        String      @id @default(uuid())
  name      String
  contact   String
  email     String?
  address   String?
  payments  SupplierPayment[]
  purchases Purchase[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Inventory {
  id            String    @id @default(uuid())
  itemName      String
  partNumber    String    @unique
  purchaseItems PurchaseItem[]
  batches       InventoryBatch[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model InventoryBatch {
  id            String    @id @default(uuid())
  inventoryId   String
  inventory     Inventory @relation(fields: [inventoryId], references: [id])
  batchNumber   String    
  quantity      Int       @default(0) // Available quantity
  purchasePrice Float
  sellingPrice  Float
  purchaseId    String?
  purchase      Purchase? @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  jobCardParts  JobCardPart[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Expense {
  id          String   @id @default(uuid())
  category    String   // RENT, UTILITIES, SALARY
  amount      Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SupplierPayment {
  id          String   @id @default(uuid())
  amount      Float
  method      String   @default("CASH")
  date        DateTime @default(now())
  reference   String?
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model TaxSetting {
  id         String   @id @default(uuid())
  name       String
  percentage Float
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
model Paymeter {
  id                 String            @id @default(uuid())
  name               String            @unique
  spentAmount        Float             @default(0)
  initialSpentAmount Float             @default(0)
  purchases          Purchase[]
  purchasePayments   PurchasePayment[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model Purchase {
  id               String            @id @default(uuid())
  purchaseNumber   String            @unique
  purchaseDate     DateTime          @default(now())
  supplierId       String
  supplier         Supplier          @relation(fields: [supplierId], references: [id])
  paymentMethodId  String
  paymentMethod    Paymeter          @relation(fields: [paymentMethodId], references: [id])
  subTotal         Float             @default(0)
  taxRate          Float             @default(0)
  taxAmount        Float             @default(0)
  discount         Float             @default(0)
  grandTotal       Float             @default(0)
  paidAmount       Float             @default(0)
  pendingAmount    Float             @default(0)
  items            PurchaseItem[]
  batches          InventoryBatch[]
  purchasePayments PurchasePayment[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model PurchaseItem {
  id            String    @id @default(uuid())
  purchaseId    String
  purchase      Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  inventoryId   String
  inventory     Inventory @relation(fields: [inventoryId], references: [id])
  quantity      Int
  purchasePrice Float
  sellingPrice  Float
  itemTotal     Float
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PurchasePayment {
  id         String   @id @default(uuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  paymeterId String
  paymeter   Paymeter @relation(fields: [paymeterId], references: [id])
  amount     Float
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
